# Root .gitignore for sistema_confeitaria

# Build output
backend/target/
**/target/
frontend/dist/
frontend/out-tsc/

# Dependency directories
frontend/node_modules/
**/node_modules/

# Environment and secrets
.env
.env.local
.env.*.local
**/.env
**/.env.*
**/secrets.properties
**/credentials.json
**/*.key
**/*.pem
**/*.der
**/*.pfx
**/*.p12
**/*.db
**/*.sqlite
**/db_backup/*.sql
**/db_backup/*.sql.gz

# IDEs and editors
.vscode/
.idea/
*.iml
*.code-workspace
.history/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# System files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Misc
coverage/
.sass-cache/
connect.lock
libpeerconnection.log
testem.log

# Docker
**/docker-compose.override.yml

# Temporary files
*.tmp
*.temp
